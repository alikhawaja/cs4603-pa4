# ─── Databricks Model Serving (LLM) ─────────────────────────────────────────
DATABRICKS_HOST=https://<your-workspace>.databricks.com
DATABRICKS_TOKEN=dapi...
DATABRICKS_MODEL=databricks-meta-llama-3-3-70b-instruct

# ─── Embeddings (managed by the Vector Search index) ────────────────────────
EMBEDDINGS_ENDPOINT=databricks-gte-large-en

# ─── Unity Catalog + Vector Search ──────────────────────────────────────────
UC_CATALOG=main
UC_SCHEMA=default
VECTOR_SEARCH_ENDPOINT=<your-name>-vs-endpoint
VECTOR_SEARCH_INDEX=main.default.<your-name>_analyst_index

# ─── Source Delta table produced by rag/ingest.py ───────────────────────────
SOURCE_TABLE=main.default.<your-name>_analyst_chunks

# ─── Deployment ─────────────────────────────────────────────────────────────
SERVING_ENDPOINT_NAME=<your-name>-document-analyst
SECRET_SCOPE=cs4603-deploy

# ─── Bonus C — remote MCP server (leave unset to use the bundled stdio server) ──
# When set, the agent connects to a standalone MCP server over streamable-http instead
# of spawning the stdio subprocess. Point this at your deployed Databricks App URL.
# MCP_SERVER_URL=https://<your-mcp-app>.databricksapps.com
